# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://retroman:CHANGE_ME@localhost:5432/retroman"

POSTGRES_DB=retroman
POSTGRES_USER=retroman
POSTGRES_PASSWORD=CHANGE_ME

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://your-domain.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"

# ─── Encryption (for API keys & MFA secrets stored in DB) ─────────────────────
# Must be exactly 32 characters — generate with: openssl rand -hex 16
ENCRYPTION_KEY="CHANGE_ME_32_CHARS_EXACTLY______"

# ─── Optional ─────────────────────────────────────────────────────────────────
HTTP_PORT=80
